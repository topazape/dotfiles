# --- font ---
font-family = "Berkeley Mono"
font-family = "LINE Seed JP"
font-size = 16
font-feature = "liga"
font-thicken = true
font-thicken-strength = 255

# --- cursor ---
shell-integration-features = no-cursor
cursor-style = block
cursor-style-blink = false

# --- copy & paste ---
keybind = super+c=copy_to_clipboard
keybind = super+v=paste_from_clipboard

# --- screen ---
keybind = super+enter=toggle_fullscreen

# --- pane: split ---
keybind = ctrl+t>minus=new_split:down
keybind = ctrl+t>shift+backslash=new_split:right

# --- pane: move ---
keybind = ctrl+t>h=goto_split:left
keybind = ctrl+t>j=goto_split:bottom
keybind = ctrl+t>k=goto_split:top
keybind = ctrl+t>l=goto_split:right
#
# # --- pane: resize ---
# keybind = ctrl+t>shift+h=resize_split:left,10
# keybind = ctrl+t>shift+j=resize_split:down,10
# keybind = ctrl+t>shift+k=resize_split:up,10
# keybind = ctrl+t>shift+l=resize_split:right,10
